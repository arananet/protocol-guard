# Database
DATABASE_URL="postgresql://protocol_tester:password@localhost:5432/protocol_tester?schema=public"

# Auth
NEXTAUTH_SECRET="your-secret-key-min-32-chars-here-change-in-production"
NEXTAUTH_URL="http://localhost:3000"

# PostgreSQL (for docker-compose)
POSTGRES_USER=protocol_tester
POSTGRES_PASSWORD=change-me-in-production
POSTGRES_DB=protocol_tester

# OAuth (optional)
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# GITHUB_CLIENT_ID=
# GITHUB_CLIENT_SECRET=

# API Security
# When set, all /api/* routes require either:
#   - An X-Api-Key header matching this value (for programmatic/curl access), or
#   - A same-origin request (dashboard — browser adds the Origin header automatically).
# Leave unset for local development; MUST be set on any internet-facing deployment.
# Generate a strong secret: openssl rand -hex 32
# API_SECRET=
